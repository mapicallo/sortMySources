{
  "name": "sortmysources-extension",
  "private": true,
  "version": "0.2.4",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && node scripts/copy-icons.mjs && vite build",
    "icons": "node scripts/generate-icons.mjs",
    "pack": "npm run build && node scripts/package-zip.mjs"
  },
  "dependencies": {
    "@sortmysources/core": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "@types/node": "^22.10.5",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.4.4",
    "sharp": "^0.33.5",
    "typescript": "~5.7.2",
    "vite": "^6.4.2"
  }
}

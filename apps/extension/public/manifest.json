{
  "manifest_version": 3,
  "name": "SortMySources",
  "version": "0.3.0",
  "description": "Maps of sources — floating panel (local IndexedDB, JSON sync with PWA)",
  "action": {
    "default_title": "SortMySources — click to open"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["tabs", "storage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

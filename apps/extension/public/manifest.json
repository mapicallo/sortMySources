{
  "manifest_version": 3,
  "name": "SortMySources",
  "version": "0.2.1",
  "description": "Add the current tab to a source map (local IndexedDB)",
  "action": {
    "default_title": "SortMySources",
    "default_popup": "popup.html"
  },
  "permissions": ["tabs"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
